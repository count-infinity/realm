      ],
      "attrs": {
        "description": "Dr. Vex is a tall, thin Centauran with pale blue skin and four slender\narms. Her multitasking ability makes her an excellent surgeon, and her\ncalm demeanor puts patients at ease. She wears a pristine white medical\ncoat with the station's insignia.",
        "strength": 9,
        "dexterity": 14,
        "intelligence": 15,
        "health": 10,
        "skill_medicine": 16,
        "hp": 9,
        "max_hp": 9,
        "cmd_heal": "$heal:say Let me take a look at you...",
