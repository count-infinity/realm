    {
      "id": "nexagen_plaza",
      "name": "Nexagen Corporate Plaza",
      "description": "",
      "tags": [
        "room",
        "zone:nexagen"
      ],
      "attrs": {
        "description": "Nexagen Tower rises fifty stories above the plaza, a monolith of dark\nglass and corporate ambition. At this hour the plaza is deserted; light\nspills from the lobby to the north. A service alley yawns to the east,\nand the tram back to the station hums behind you."
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
    {
      "id": "nexagen_alley",
      "name": "Service Alley",
      "description": "",
      "tags": [
        "dark",
        "room",
        "zone:nexagen"
      ],
      "attrs": {
        "description": "Dumpsters and steam vents crowd this narrow alley along the tower's\neast face. A rusted fire escape zigzags up the wall, its lowest ladder\nretracted well out of easy reach."
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
    {
      "id": "nexagen_lobby",
      "name": "Nexagen Tower Lobby",
      "description": "",
      "tags": [
        "room",
        "zone:nexagen"
      ],
      "attrs": {
        "description": "Polished marble and a five-meter holographic Nexagen logo dominate the\nlobby. The reception desk is shuttered for the night. A security\nstation guards the stairwell entrance to the north."
      },
      "locks": {},
