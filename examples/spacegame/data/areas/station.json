  "objects": [
    {
      "id": "room_docking_bay",
      "name": "Docking Bay Alpha-1",
      "description": "",
      "tags": [
        "indoor",
        "room",
        "start_room",
        "zone:station_alpha"
      ],
      "attrs": {
        "description": "You stand in a cavernous docking bay, its metallic walls humming with the\nconstant thrum of environmental systems. Massive airlocks line the eastern\nwall, currently sealed against the vacuum of space. Cargo containers are\nstacked neatly in designated zones, and a few small shuttles rest in their\nberths.\n\nA corridor leads NORTH to the station's interior. A security checkpoint\nguards the way SOUTH to the restricted areas."
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
    {
      "id": "room_promenade",
      "name": "Station Promenade",
      "description": "",
      "tags": [
        "indoor",
        "room",
        "zone:station_alpha"
      ],
      "attrs": {
        "description": "The promenade is the social heart of Space Station Alpha. Holographic\nadvertisements flicker overhead, hawking everything from ship upgrades to\nexotic alien cuisine. Vendors have set up kiosks along the curved walkway,\nand the distant stars are visible through reinforced viewports.\n\nThe docking bay lies to the SOUTH. A cantina beckons to the WEST, while\nthe medical bay is to the EAST. NORTH leads to the station command center."
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
    {
      "id": "room_cantina",
      "name": "The Void's Edge Cantina",
      "description": "",
      "tags": [
        "indoor",
        "room",
        "zone:station_alpha"
      ],
      "attrs": {
        "description": "Dim lighting and the smell of recycled air mixed with exotic spices greet\nyou. The cantina is a favorite gathering spot for spacers, traders, and\nthose who prefer not to answer too many questions. A long bar runs along\none wall, tended by a grizzled human bartender. Booths line the opposite\nwall, offering privacy for deals both legal and otherwise.\n\nMusic from a dozen worlds plays softly from hidden speakers."
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
    {
      "id": "room_medbay",
      "name": "Medical Bay",
      "description": "",
      "tags": [
        "indoor",
        "room",
        "zone:station_alpha"
      ],
      "attrs": {
        "description": "Sterile white walls and the sharp scent of antiseptic define the station's\nmedical facility. Diagnostic beds with holographic readouts line one wall,\nwhile medical supply cabinets occupy another. An autodoc unit stands ready\nin the corner, its robotic arms folded in standby mode.\n\nA sign reads: \"Dr. Vex - Chief Medical Officer\""
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
    {
      "id": "room_command",
      "name": "Station Command Center",
      "description": "",
      "tags": [
        "indoor",
        "restricted",
        "room",
        "zone:station_alpha"
      ],
      "attrs": {
        "description": "The nerve center of Space Station Alpha hums with activity. Banks of\ndisplays show sensor readouts, ship traffic, and system status. Officers\nmonitor their stations with practiced efficiency, and the station\ncommander's chair dominates the center of the room.\n\nA tactical holotable displays the local sector in three dimensions.",
        "lock_enter": "caller.has_tag('crew') or caller.has_tag('admin')"
      },
      "locks": {},
      "behaviors": [],
      "location": null,
      "owner": null,
      "parent": null
    },
